{
  "name": "@seunghwan/conitens",
  "version": "4.2.0",
  "private": false,
  "type": "module",
  "description": "Conitens — Multi-Agent AI Orchestration System for Collaborative Development",
  "keywords": [
    "ai",
    "agent",
    "orchestration",
    "cli",
    "gemini",
    "claude",
    "codex",
    "conitens",
    "multi-agent",
    "collaboration"
  ],
  "author": "Seunghwan",
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "workspaces": ["packages/*"],
  "bin": {
    "ensemble": "./bin/ensemble.js",
    "conitens": "./bin/ensemble.js"
  },
  "files": [
    "bin/",
    "scripts/",
    ".agent/agents/",
    ".agent/policies/",
    ".agent/providers/",
    ".agent/rooms/",
    ".agent/rules/",
    ".agent/skills/",
    ".agent/workflows/",
    ".agent/workspaces/",
    ".agents/",
    ".notes/README.md",
    ".vibe/",
    "vibe-kit/",
    "AGENTS.md",
    "CLAUDE.md",
    "CONITENS.md",
    "USAGE_GUIDE.md"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/seunghwaneom/Conitens"
  },
  "homepage": "https://github.com/seunghwaneom/Conitens#readme",
  "publishConfig": {
    "access": "public"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom": "0.8.12",
      "brace-expansion@^1.1.0": "1.1.13",
      "brace-expansion@^2.0.0": "2.0.3",
      "electron-builder-squirrel-windows": "26.8.1",
      "picomatch@^4.0.0": "4.0.4"
    }
  },
  "bugs": {
    "url": "https://github.com/seunghwaneom/Conitens/issues"
  },
  "scripts": {
    "postinstall": "node ./bin/postinstall.cjs",
    "test": "pnpm -r test",
    "build": "pnpm -r build"
  }
}
