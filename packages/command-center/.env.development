# Conitens Command Center — Development Environment Overrides
# Loaded automatically when running `vite` (dev mode).
# These values override .env for local development only.

# Mark the tab title so it's easy to distinguish dev from production windows.
VITE_APP_TITLE=Conitens Command Center [DEV]

# Point to the local orchestrator WebSocket bus.
# Override if your local @conitens/core server runs on a different port.
VITE_WS_URL=ws://localhost:8080
