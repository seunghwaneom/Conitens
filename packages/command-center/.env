# Conitens Command Center — Shared Environment Variables
# Values here are loaded in all environments (dev, test, production).
# VITE_* variables are exposed to client code via import.meta.env.
# Non-VITE_* variables are build-time only (never exposed to the browser).

# ── Orchestrator connection ────────────────────────────────────────────────
# WebSocket URL for the @conitens/core orchestrator event bus.
# Must be a valid ws:// or wss:// URL.
# The 3D GUI will attempt to connect here for live event data;
# it silently falls back to simulated data if unavailable.
VITE_WS_URL=ws://localhost:8080

# HTTP base URL for the control-plane REST API (Sub-AC 7c: metrics billboards).
# Used by useControlPlaneMetrics to poll per-agent and per-room live metrics:
#   GET <VITE_API_BASE_URL>/api/agents/{id}/metrics
#   GET <VITE_API_BASE_URL>/api/rooms/{id}/metrics
# Falls back to metrics-store simulated data when this endpoint is unavailable.
VITE_API_BASE_URL=http://localhost:8080

# ── Application metadata ───────────────────────────────────────────────────
# Browser tab / window title.
VITE_APP_TITLE=Conitens Command Center

# ── Deployment ─────────────────────────────────────────────────────────────
# Base URL for all HTML/asset links.  Change this if deploying to a subpath.
# Example: VITE_BASE_URL=/command-center/
# Leave as "/" for root-path deployment (typical for localhost).
VITE_BASE_URL=/
