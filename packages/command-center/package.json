{
  "name": "@conitens/command-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:web": "vite build",
    "build:web:verify": "node scripts/verify-web-build.mjs",
    "build:preview": "pnpm build && vite preview",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "generate:sprites": "tsx scripts/generate-sprite-sheets.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "node scripts/ci-test-count-check.mjs",
    "test:ci:replay-scale": "node scripts/ci-test-count-check.mjs --file replay-playback-scale --min 8",
    "build:electron-main": "esbuild electron/main.ts electron/preload.ts --bundle --platform=node --packages=external --outdir=dist-electron --out-extension:.js=.cjs --format=cjs --target=node22",
    "electron:dev": "concurrently -k -n VITE,ELECTRON -c cyan,green \"vite --mode electron\" \"wait-on http://localhost:3100 && electron .\"",
    "electron:build": "pnpm build:electron-main && vite build --mode electron",
    "electron:dist": "pnpm electron:build && electron-builder --config electron-builder.config.cjs",
    "electron:dist:win": "pnpm electron:build && electron-builder --win --config electron-builder.config.cjs",
    "electron:dist:mac": "pnpm electron:build && electron-builder --mac --config electron-builder.config.cjs",
    "electron:dist:linux": "pnpm electron:build && electron-builder --linux --config electron-builder.config.cjs"
  },
  "dependencies": {
    "@conitens/protocol": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.175.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.175.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.24.0",
    "jsdom": "^29.0.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0",
    "wait-on": "^8.0.0"
  }
}
