{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "user_agent",
        "agent_agent",
        "agent_agent_user"
      ]
    },
    "workspace": {
      "type": "string",
      "minLength": 1
    },
    "run": {
      "type": "string"
    },
    "participants": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "closed",
        "archived"
      ]
    },
    "visibility": {
      "default": "internal",
      "type": "string",
      "enum": [
        "internal",
        "external"
      ]
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$"
    },
    "tags": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "linked_notes": {
      "default": [],
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "prompt_tokens_est": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "completion_tokens_est": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "compression_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "source_message_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "id",
    "kind",
    "workspace",
    "participants",
    "status",
    "visibility",
    "created_at",
    "updated_at",
    "tags",
    "linked_notes"
  ],
  "additionalProperties": false
}
