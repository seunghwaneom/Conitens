{
  "name": "@conitens/tui",
  "version": "0.1.0",
  "description": "Conitens v2 terminal UI — Ink-based monitoring dashboard",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" }
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --loader ts-node/esm src/index.tsx"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@conitens/core": "workspace:*",
    "@conitens/protocol": "workspace:*",
    "ink": "^5.1.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
